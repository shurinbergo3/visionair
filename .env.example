# Bing IndexNow API key.
# Must match the filename in /public/{KEY}.txt (currently d3d8ee55480da8b67e9d447173b8cce0.txt).
# Used by scripts/notify-indexnow.mjs in the postbuild step on Vercel production.
INDEXNOW_KEY=d3d8ee55480da8b67e9d447173b8cce0

# Telegram bot — receives contact-form briefs and admin commands.
# Get a token from @BotFather. The main admin can add other admins via /addadmin.
TELEGRAM_BOT_TOKEN=
TELEGRAM_MAIN_ADMIN_ID=
# Random string used to verify webhook calls really come from Telegram.
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Path used to persist admin list and lead archive (JSON).
# Defaults: ./data/store.json locally, /tmp/visionair-store.json on Vercel.
# For multi-instance production, move to Vercel KV / Postgres.
# STORAGE_PATH=
