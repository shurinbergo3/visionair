# Bing IndexNow API key.
# Must match the filename in /public/{KEY}.txt (currently d3d8ee55480da8b67e9d447173b8cce0.txt).
# Used by scripts/notify-indexnow.mjs in the postbuild step on Vercel production.
INDEXNOW_KEY=d3d8ee55480da8b67e9d447173b8cce0

# Resend API key for contact form delivery (app/api/contact/route.ts).
# Get one at https://resend.com/api-keys
RESEND_API_KEY=

# Inbox that receives contact briefs.
CONTACT_INBOX=hello@visionair.site
